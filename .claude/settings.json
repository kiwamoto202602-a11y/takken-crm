{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/credentials/**)",
      "Read(**/*secret*)",
      "Read(**/*password*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-activation.sh"
          }
        ]
      }
    ]
  }
}
